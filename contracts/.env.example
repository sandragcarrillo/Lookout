# Deployer wallet
# The wallet that will OWN the TrustRegistry (can rotate auditor, transfer ownership).
# Use a fresh wallet for testnets — never reuse a mainnet key.
# Foundry expects the raw hex private key WITHOUT the 0x prefix.
# ------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=your_private_key_here_no_0x_prefix

# ------------------------------------------------------------
# Auditor wallet
# The Lookout agent wallet that will WRITE scores (calls updateScore).
# This is the address only — not a private key.
# Can be the same as deployer for testnet. Should be separate on mainnet.
# ------------------------------------------------------------
AUDITOR_WALLET=0xYourAuditorWalletAddress

# ------------------------------------------------------------
# RPC endpoints
# Celo Sepolia (testnet): get a free key at alchemy.com → create app → Celo → Celo Sepolia
# ------------------------------------------------------------
CELO_TESTNET_RPC_URL=https://celo-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE
CELO_RPC_URL=https://forno.celo.org
BASE_RPC_URL=https://mainnet.base.org

# ------------------------------------------------------------
# Block explorer API keys (for --verify flag during deployment)
# Alfajores testnet uses Blockscout — no API key needed, already configured in foundry.toml.
# Celo mainnet:  https://celoscan.io/myapikey
# Basescan:      https://basescan.org/myapikey
# ------------------------------------------------------------
CELOSCAN_API_KEY=your_celoscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here
